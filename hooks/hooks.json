{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sleep 2 && test -f ~/.claude-speak/env && . ~/.claude-speak/env; node \"${CLAUDE_PLUGIN_ROOT}/dist/cli.js\" --trigger stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f ~/.claude-speak/env && . ~/.claude-speak/env; node \"${CLAUDE_PLUGIN_ROOT}/dist/cli.js\" --trigger notification"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -n \"${CLAUDE_PLUGIN_ROOT}\" && (test -d \"${CLAUDE_PLUGIN_ROOT}/node_modules/openai\" || (cd \"${CLAUDE_PLUGIN_ROOT}\" && npm install --omit=dev)) || true"
          },
          {
            "type": "command",
            "command": "mkdir -p ~/.claude-speak && printf '%s' \"${CLAUDE_PLUGIN_ROOT}\" > ~/.claude-speak/plugin-root && printf '%s' \"${CLAUDE_PLUGIN_DATA}\" > ~/.claude-speak/plugin-data"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/check-setup.sh\""
          }
        ]
      }
    ]
  }
}
