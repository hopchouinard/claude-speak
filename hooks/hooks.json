{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sleep 2 && test -f ~/.claude-speak/env && . ~/.claude-speak/env; node \"${CLAUDE_PLUGIN_ROOT}/dist/cli.js\" --trigger stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f ~/.claude-speak/env && . ~/.claude-speak/env; node \"${CLAUDE_PLUGIN_ROOT}/dist/cli.js\" --trigger notification"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -n \"${CLAUDE_PLUGIN_DATA}\" && mkdir -p \"${CLAUDE_PLUGIN_DATA}\" && (diff -q \"${CLAUDE_PLUGIN_ROOT}/package.json\" \"${CLAUDE_PLUGIN_DATA}/package.json\" >/dev/null 2>&1 || (cd \"${CLAUDE_PLUGIN_DATA}\" && cp \"${CLAUDE_PLUGIN_ROOT}/package.json\" . && npm install) || rm -f \"${CLAUDE_PLUGIN_DATA}/package.json\") || true"
          },
          {
            "type": "command",
            "command": "mkdir -p ~/.claude-speak && ln -sfn \"${CLAUDE_PLUGIN_ROOT}/dist\" ~/.claude-speak/dist && ln -sfn \"${CLAUDE_PLUGIN_DATA}/node_modules\" \"${CLAUDE_PLUGIN_ROOT}/node_modules\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/check-setup.sh\""
          }
        ]
      }
    ]
  }
}
